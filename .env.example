# Network to operate on. Default is testnet-10 (safe, fake KAS from a faucet).
KASPA_NETWORK=testnet-10

# Set to "true" only if you deliberately want this agent to control real mainnet funds.
KASPA_ALLOW_MAINNET=false

# wRPC endpoint of a Kaspa node for the selected network (your own
# `kaspad --utxoindex`, or a trusted public node). There is no bundled
# public resolver in this SDK build, so this must be set explicitly.
# Example shape: ws://<host>:<port>
KASPA_NODE_URL=

# Hex-encoded private key. Generate one with: npm run setup-wallet
# NEVER commit this file with a real key in it. Keep .env out of git (already in .gitignore).
KASPA_PRIVATE_KEY_HEX=

# Safety cap: send_payment refuses any single transfer above this amount (in KAS).
KASPA_MAX_SEND_KAS=50
